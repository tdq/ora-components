{
  "name": "a1-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.7.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "dev": "turbo dev",
    "storybook": "turbo storybook",
    "pack:local": "turbo run pack:local --filter=aura-components",
    "mcp:build": "turbo run build --filter=aura-mcp-server",
    "mcp:start": "node packages/mcp-server/dist/index.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
