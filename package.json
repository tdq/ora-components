{
  "name": "ora-monorepo",
  "type": "module",
  "packageManager": "npm@10.7.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "dev": "turbo dev",
    "storybook": "turbo storybook",
    "pack:local": "turbo run pack:local --filter=@tdq/ora-components",
    "mcp:build": "turbo run build --filter=ora-mcp-server",
    "mcp:start": "node packages/mcp-server/dist/index.js",
    "mcp:landing": "turbo run serve --filter=ora-mcp-server",
    "landing:build": "turbo run build --filter=landing-page",
    "landing:start": "turbo run dev --filter=landing-page"
  },
  "overrides": {
    "storybook": "10.3.6"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0"
  }
}