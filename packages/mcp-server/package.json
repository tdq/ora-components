{
  "name": "ora-mcp-server",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "npm run build:css && tsc && node scripts/stage-api.mjs",
    "build:tsc": "tsc",
    "build:css": "tailwindcss -i ./public/src-styles.css -o ./public/styles.css",
    "dev": "tsc --watch",
    "serve": "npx serve public",
    "start": "node dist/index.js",
    "start:http": "func start --script-root api"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tdq/ora-components": "*",
    "ora-examples": "*",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
