{
  "name": "aura-components",
  "version": "0.1.1",
  "description": "A1 Web Components library",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": {
      "import": "./dist/a1-components.css",
      "default": "./dist/a1-components.css"
    },
    "./button": {
      "import": "./dist/button/index.js",
      "types": "./dist/button/index.d.ts"
    },
    "./chart": {
      "import": "./dist/chart/index.js",
      "types": "./dist/chart/index.d.ts"
    },
    "./checkbox": {
      "import": "./dist/checkbox/index.js",
      "types": "./dist/checkbox/index.d.ts"
    },
    "./combobox": {
      "import": "./dist/combobox/index.js",
      "types": "./dist/combobox/index.d.ts"
    },
    "./datepicker": {
      "import": "./dist/datepicker/index.js",
      "types": "./dist/datepicker/index.d.ts"
    },
    "./dialog": {
      "import": "./dist/dialog/index.js",
      "types": "./dist/dialog/index.d.ts"
    },
    "./form": {
      "import": "./dist/form/index.js",
      "types": "./dist/form/index.d.ts"
    },
    "./grid": {
      "import": "./dist/grid/index.js",
      "types": "./dist/grid/index.d.ts"
    },
    "./label": {
      "import": "./dist/label/index.js",
      "types": "./dist/label/index.d.ts"
    },
    "./layout": {
      "import": "./dist/layout/index.js",
      "types": "./dist/layout/index.d.ts"
    },
    "./listbox": {
      "import": "./dist/listbox/index.js",
      "types": "./dist/listbox/index.d.ts"
    },
    "./numberfield": {
      "import": "./dist/numberfield/index.js",
      "types": "./dist/numberfield/index.d.ts"
    },
    "./panel": {
      "import": "./dist/panel/index.js",
      "types": "./dist/panel/index.d.ts"
    },
    "./tabs": {
      "import": "./dist/tabs/index.js",
      "types": "./dist/tabs/index.d.ts"
    },
    "./textfield": {
      "import": "./dist/textfield/index.js",
      "types": "./dist/textfield/index.d.ts"
    },
    "./toolbar": {
      "import": "./dist/toolbar/index.js",
      "types": "./dist/toolbar/index.d.ts"
    },
    "./router": {
      "import": "./dist/router/index.js",
      "types": "./dist/router/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:css && npm run build:types && node scripts/reorganize-types.mjs && node scripts/generate-manifest.mjs",
    "build:css": "tailwindcss -i ./src/index.css -o ./dist/a1-components.css --minify",
    "build:types": "tsc -p tsconfig.build.json",
    "test": "jest",
    "pack:local": "npm run build && npm pack"
  },
  "peerDependencies": {
    "rxjs": "^7.8.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^29.5.14",
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  }
}
